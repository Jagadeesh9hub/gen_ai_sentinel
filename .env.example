# SENTINEL environment template — copy to .env and fill in as needed.
# Phase 1 (local data layer) needs NONE of these.

# --- Local ---
SENTINEL_DUCKDB=data/sentinel.duckdb

# --- LLM (agent phase) ---
# For local agent validation you can use a free Google AI Studio key (no GCP project).
# Leave blank to use the deterministic mock LLM provider.
LLM_PROVIDER=mock            # mock | gemini | vertex
GEMINI_API_KEY=

# --- Google Cloud (deployment phase) ---
GCP_PROJECT_ID=
GCP_REGION=us-central1
